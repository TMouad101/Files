mport math
from turtle import *

def findout_a(k):
    return 15 * math.sin(k) ** 3

def findout_b(k):
    return 12 * math.cos(k) - 5 * math.cos(2 * k) - 2 * math.cos(3 * k) - math.cos(4 * k)

speed(50)

bgcolor("black")
penup()
goto(0, 150)
pendown()
color("white")
write("Aya", align="center", font=("Arial", 24, "normal"))

# Draw the findout_ shape
for i in range(6000):
    goto(findout_a(i) * 20, findout_b(i) * 20)
    for j in range(5):
        color("red")
    goto(0, 0)

done()
